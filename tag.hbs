{{!< default}}
{{#tag}}{{#match slug "visualizing"}}{{#contentFor "body_class"}} is-nights-tag{{/contentFor}}{{else match slug "not-using-ai-for"}}{{#contentFor "body_class"}} is-nights-tag{{/contentFor}}{{else match slug "organizing"}}{{#contentFor "body_class"}} is-nights-tag{{/contentFor}}{{else match slug "curating"}}{{#contentFor "body_class"}} is-nights-tag{{/contentFor}}{{/match}}{{/tag}}
<main class="site-main sidebar-layout tag-archive">

  <button class="sidebar-toggle" type="button" aria-controls="sidebar" aria-expanded="false">
    <span class="sidebar-toggle-icon" aria-hidden="true"></span>
    Menu
  </button>

  <aside class="sidebar" id="sidebar">
    {{> "sidebar-header"}}

    <nav class="sidebar-nav" id="tag-nav">
      <p class="sidebar-nav-heading">Spending my days on</p>
      <ul class="sidebar-nav-list">
        {{> "tag-nav-item" slug="designing" label="Designing" current=tag.slug}}
        {{> "tag-nav-item" slug="observing" label="Observing" current=tag.slug}}
        {{> "tag-nav-item" slug="using-ai-for" label="Using AI for" current=tag.slug}}
      </ul>

      <p class="sidebar-nav-heading">Spending my nights on</p>
      <ul class="sidebar-nav-list">
        {{> "tag-nav-item" slug="visualizing" label="Visualizing" current=tag.slug}}
        {{> "tag-nav-item" slug="not-using-ai-for" label="Not using AI for" current=tag.slug}}
        {{> "tag-nav-item" slug="organizing" label="Organizing" current=tag.slug}}
      </ul>
    </nav>
  </aside>

  <div class="sidebar-overlay" aria-hidden="true"></div>

  <div class="tag-main">
    {{#tag}}
    <h1 class="tag-title">{{name}}</h1>

    <hr class="tag-rule" />

    <p class="tag-count">
      {{#get "posts" filter="tag:{{slug}}" limit="1"}}{{pagination.total}} {{#match pagination.total "1"}}post{{else}}posts{{/match}}{{/get}}{{#get "posts" filter="tag:{{slug}}+featured:true" limit="1"}}{{#if pagination.total}} &middot; {{pagination.total}} ongoing{{/if}}{{/get}}
    </p>

    <div class="tag-post-list">
      {{#get "posts" filter="tag:{{slug}}" limit="100" include="tags" order="featured desc, published_at desc" as |tagposts|}}
        {{#foreach tagposts}}{{> "portfolio-sections/tag-post"}}{{/foreach}}
      {{/get}}
    </div>
    {{/tag}}
  </div>

</main>
