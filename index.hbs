{{!< default}}
<main class="site-main">

  <div class="portfolio-mobile-header">
    <h2 class="portfolio-mobile-section-title"></h2>
  </div>

  <div class="portfolio-hero">
    <h1 class="portfolio-name">Divya Prabhakar</h1>
    <div class="portfolio-tagline">
      <p class="portfolio-bio">I build experiences users trust, products that compound in value, and
        operationalized design cultures that scale.
      </p>
      <p class="portfolio-role">Currently: Head of Digital Product Design at
        <a
          class="portfolio-link"
          href="https://www.formenergy.com"
          target="_blank"
          rel="noopener noreferrer"
        >Form Energy</a>, building energy storage for a clean and reliable grid. </p>

    </div>

  </div>

  <div class="portfolio-layout">

    <nav class="portfolio-sidebar">
      {{> "portfolio-nav"}}
    </nav>

    <div class="portfolio-content-area">

      <div id="section-designing" class="portfolio-section visible in-group">
        <h3 class="portfolio-section-group-label">Designing</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:designing" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div id="section-developing" class="portfolio-section visible in-group">
        <h3 class="portfolio-section-group-label">Developing</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:developing" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div id="section-observing" class="portfolio-section visible in-group">
        <h3 class="portfolio-section-group-label">Observing</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:observing" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div id="section-curating" class="portfolio-section">
        <h3 class="portfolio-section-group-label">Curating</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:curating" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div id="section-organizing" class="portfolio-section">
        <h3 class="portfolio-section-group-label">Organizing</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:organizing" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div id="section-using-ai-for" class="portfolio-section">
        <h3 class="portfolio-section-group-label">Using AI for</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:using-ai-for" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div id="section-not-using-ai-for" class="portfolio-section">
        <h3 class="portfolio-section-group-label">Not using AI for</h3>
        <div class="portfolio-section-grid">
          {{#get "posts" limit="20" filter="tag:not-using-ai-for" order="published_at desc" as |posts meta|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

    </div>
  </div>

</main>
