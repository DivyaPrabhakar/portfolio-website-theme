{{!< default}}
<main class="site-main">

  <header class="portfolio-hero">
    <h1 class="portfolio-name">Divya Prabhakar</h1>
    <div class="portfolio-tagline">
      <p class="portfolio-bio">I build experiences users trust, products that compound in value, and
        operationalized design cultures that scale.</p>
      <p class="portfolio-role">Currently:
        <a
          class="portfolio-link"
          href="https://www.linkedin.com/in/divyaprabhakar/"
          target="_blank"
          rel="noopener noreferrer"
        >Head of Digital Product Design</a> at
        <a
          class="portfolio-link"
          href="https://www.formenergy.com"
          target="_blank"
          rel="noopener noreferrer"
        >Form Energy</a>, building energy storage for a clean and reliable grid.</p>
    </div>
  </header>

  <div class="portfolio-columns">

    {{!-- ── Spending my days on ── --}}
    <section class="portfolio-column portfolio-column--days">
      <h2 class="portfolio-column-heading">Spending my days on</h2>

      {{> "portfolio-sections/subsection" label="Designing" slug="designing"}}
      {{> "portfolio-sections/subsection" label="Observing" slug="observing" articles=true}}
      {{> "portfolio-sections/subsection" label="Using AI for" slug="using-ai-for"}}
    </section>

    {{!-- ── Spending my nights on ── --}}
    <section class="portfolio-column portfolio-column--nights">
      <h2 class="portfolio-column-heading">Spending my nights on</h2>

      <div class="portfolio-nights-grid">

        {{> "portfolio-sections/subsection" label="Visualizing" slug="visualizing"}}
        {{> "portfolio-sections/subsection" label="Not using AI for" slug="not-using-ai-for"}}
        {{> "portfolio-sections/subsection" label="Organizing" slug="organizing"}}

      </div>
    </section>

  </div>

</main>
