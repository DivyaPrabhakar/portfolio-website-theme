{{!< default}}
<main class="site-main">

  <div class="portfolio-hero">
    <h1 class="portfolio-name">Divya Prabhakar</h1>
    <div class="portfolio-tagline">
      <p>I build experiences users trust, products compound in value, and
        user-centered design cultures that scale.
      </p>
      <p class="portfolio-role">Currently: Head of Digital Product Design at
        <a
          class="portfolio-link"
          href="https://www.formenergy.com"
          target="_blank"
          rel="noopener noreferrer"
        >Form Energy</a></p>

    </div>

  </div>

  <div class="portfolio-layout">

    <nav class="portfolio-sidebar">
      <p class="portfolio-sidebar-label">What I am...</p>
      <ul class="portfolio-nav-list">
        <li><button
            class="portfolio-nav-item active"
            data-section="spending-my-days-on"
          >Spending my days on</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="spending-my-nights-on"
          >Spending my nights on</button></li>
        <li><button class="portfolio-nav-item" data-section="proud-of">Proud of</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="observing"
          >Observing</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="curating"
          >Curating</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="organizing"
          >Organizing</button></li>
        <li><button class="portfolio-nav-item" data-section="using-ai-for">Using
            AI for</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="not-using-ai-for"
          >Not using AI for</button></li>
        <li>
          <button
            class="portfolio-nav-item portfolio-see-all"
            data-section="see-everything"
          >See everything</button>
        </li>
      </ul>

    </nav>

    <div class="portfolio-content-area">

      <div id="section-thinking-about" class="portfolio-section visible">
        {{#get
          "posts"
          limit="20"
          filter="tag:thinking-about"
          order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              <span class="portfolio-post-date">{{date
                  published_at
                  format="MMM YYYY"
                }}</span>
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
              <div class="portfolio-post-tags">
                {{#foreach tags}}
                  <span class="portfolio-tag-pill">{{name}}</span>
                {{/foreach}}
              </div>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-coding" class="portfolio-section">
        {{#get
          "posts" limit="20" filter="tag:coding" order="published_at desc"
          as |posts meta|
        }}
          <div class="portfolio-coding-grid">
            {{#foreach posts}}
              <div class="portfolio-coding-item">
                {{#if feature_image}}
                  <img
                    src="{{img_url feature_image size="s"}}"
                    alt="{{title}}"
                    class="portfolio-coding-thumb"
                  />
                {{/if}}
                <div class="portfolio-post-tags">
                  {{#foreach tags}}
                    <span class="portfolio-tag-pill">{{name}}</span>
                  {{/foreach}}
                </div>
                <a href="{{url}}" class="portfolio-post-link">
                  <h4 class="portfolio-post-title">{{title}}</h4>
                </a>
                <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
              </div>
            {{/foreach}}
          </div>
        {{/get}}
      </div>

      <div id="section-spending-my-nights-on" class="portfolio-section">
        {{#get
          "posts"
          limit="20"
          filter="tag:spending-nights-on"
          order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              <span class="portfolio-post-date">{{date
                  published_at
                  format="MMM YYYY"
                }}</span>
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
              <div class="portfolio-post-tags">
                {{#foreach tags}}
                  <span class="portfolio-tag-pill">{{name}}</span>
                {{/foreach}}
              </div>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-proud-of" class="portfolio-section">
        {{#get
          "posts" limit="20" filter="tag:proud-of" order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-wearing" class="portfolio-section">
        {{#get
          "posts" limit="20" filter="tag:wearing" order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item portfolio-post-item--with-thumb">
              {{#if feature_image}}
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  class="portfolio-post-thumb"
                />
              {{/if}}
              <div class="portfolio-post-text">
                <a href="{{url}}" class="portfolio-post-link">
                  <h4 class="portfolio-post-title">{{title}}</h4>
                </a>
                <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
              </div>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-organizing" class="portfolio-section">
        {{#get
          "posts" limit="20" filter="tag:organizing" order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
              <div class="portfolio-post-tags">
                {{#foreach tags}}
                  <span class="portfolio-tag-pill">{{name}}</span>
                {{/foreach}}
              </div>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-continuing" class="portfolio-section">
        {{#get
          "posts" limit="20" filter="tag:continuing" order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              {{#if custom_excerpt}}
                <p class="portfolio-post-excerpt">{{custom_excerpt}}</p>
              {{else}}
                <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
              {{/if}}
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-noticing" class="portfolio-section">
        {{#get
          "posts" limit="20" filter="tag:noticing" order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-noticing-item">
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-noticing-header">{{title}}</h4>
              </a>
              <p class="portfolio-noticing-body">{{excerpt words="10"}}</p>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

      <div id="section-see-everything" class="portfolio-section">
        {{#get "posts" limit="50" order="published_at desc" as |posts meta|}}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              {{#primary_tag}}
                <span class="portfolio-section-label">{{name}}</span>
              {{/primary_tag}}
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              <p class="portfolio-post-excerpt">{{excerpt words="10"}}</p>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

    </div>
  </div>

</main>