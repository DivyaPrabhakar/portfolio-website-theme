{{!< default}}
<main class="site-main">

  <header class="portfolio-hero">
    <h1 class="portfolio-name">Divya Prabhakar</h1>
    <div class="portfolio-tagline">
      <p class="portfolio-bio">I build experiences users trust, products that compound in value, and
        operationalized design cultures that scale.</p>
      <p class="portfolio-role">Currently:
        <a
          class="portfolio-link"
          href="https://www.linkedin.com/in/divyaprabhakar/"
          target="_blank"
          rel="noopener noreferrer"
        >Head of Digital Product Design</a> at
        <a
          class="portfolio-link"
          href="https://www.formenergy.com"
          target="_blank"
          rel="noopener noreferrer"
        >Form Energy</a>, building energy storage for a clean and reliable grid.</p>
    </div>
  </header>

  <div class="portfolio-columns">

    {{!-- ── Spending my days on ── --}}
    <section class="portfolio-column portfolio-column--days">
      <h2 class="portfolio-column-heading">Spending my days on</h2>
      <p class="portfolio-column-subtitle">Design leadership, engineering, and observations about systems</p>

      <div class="portfolio-subsection">
        <div class="portfolio-subsection-head">
          <span class="portfolio-subsection-label">Designing</span>
          <a class="portfolio-see-all" href="/tag/designing/">See all</a>
        </div>
        <div class="portfolio-item-list">
          {{#get "posts" limit="2" filter="tag:designing" order="published_at desc" as |posts|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div class="portfolio-subsection">
        <div class="portfolio-subsection-head">
          <span class="portfolio-subsection-label">Developing</span>
          <a class="portfolio-see-all" href="/tag/developing/">See all</a>
        </div>
        <div class="portfolio-item-list">
          {{#get "posts" limit="2" filter="tag:developing" order="published_at desc" as |posts|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div class="portfolio-subsection">
        <div class="portfolio-subsection-head">
          <span class="portfolio-subsection-label">Observing</span>
          <a class="portfolio-see-all" href="/tag/observing/">See all</a>
        </div>
        <div class="portfolio-item-list">
          {{#get "posts" limit="2" filter="tag:observing" order="published_at desc" as |posts|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>

      <div class="portfolio-subsection">
        <div class="portfolio-subsection-head">
          <span class="portfolio-subsection-label">Visualizing</span>
          <a class="portfolio-see-all" href="/tag/visualizing/">See all</a>
        </div>
        <div class="portfolio-item-list">
          {{#get "posts" limit="2" filter="tag:visualizing" order="published_at desc" as |posts|}}
            {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
          {{/get}}
        </div>
      </div>
    </section>

    {{!-- ── Spending my nights on ── --}}
    <section class="portfolio-column portfolio-column--nights">
      <h2 class="portfolio-column-heading">Spending my nights on</h2>
      <p class="portfolio-column-subtitle">The newsletter, the data viz, the parenting, the tinkering.</p>

      <div class="portfolio-nights-grid">

        <div class="portfolio-subsection">
          <div class="portfolio-subsection-head">
            <span class="portfolio-subsection-label">Curating</span>
            <a class="portfolio-see-all" href="/tag/curating/">See all</a>
          </div>
          <div class="portfolio-item-list">
            {{#get "posts" limit="2" filter="tag:curating" order="published_at desc" as |posts|}}
              {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
            {{/get}}
          </div>
        </div>

        <div class="portfolio-subsection">
          <div class="portfolio-subsection-head">
            <span class="portfolio-subsection-label">Organizing</span>
            <a class="portfolio-see-all" href="/tag/organizing/">See all</a>
          </div>
          <div class="portfolio-item-list">
            {{#get "posts" limit="2" filter="tag:organizing" order="published_at desc" as |posts|}}
              {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
            {{/get}}
          </div>
        </div>

        <div class="portfolio-subsection">
          <div class="portfolio-subsection-head">
            <span class="portfolio-subsection-label">Using AI for</span>
            <a class="portfolio-see-all" href="/tag/using-ai-for/">See all</a>
          </div>
          <div class="portfolio-item-list">
            {{#get "posts" limit="2" filter="tag:using-ai-for" order="published_at desc" as |posts|}}
              {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
            {{/get}}
          </div>
        </div>

        <div class="portfolio-subsection">
          <div class="portfolio-subsection-head">
            <span class="portfolio-subsection-label">Not using AI for</span>
            <a class="portfolio-see-all" href="/tag/not-using-ai-for/">See all</a>
          </div>
          <div class="portfolio-item-list">
            {{#get "posts" limit="2" filter="tag:not-using-ai-for" order="published_at desc" as |posts|}}
              {{#foreach posts}}{{> "portfolio-sections/post-card"}}{{/foreach}}
            {{/get}}
          </div>
        </div>

      </div>
    </section>

  </div>

</main>
