{{!< default}}
<main class="site-main">

  <div class="portfolio-mobile-header">
    <h2 class="portfolio-mobile-section-title"></h2>
  </div>

  <div class="portfolio-hero">
    <h1 class="portfolio-name">Divya Prabhakar</h1>
    <div class="portfolio-tagline">
      <p>I build experiences users trust, products that compound in value, and
        operationalized design cultures that scale.
      </p>
      <p class="portfolio-role">Currently: Head of Digital Product Design at
        <a
          class="portfolio-link"
          href="https://www.formenergy.com"
          target="_blank"
          rel="noopener noreferrer"
        >Form Energy</a>, building energy storage for a clean and reliable grid. </p>

    </div>

  </div>

  <div class="portfolio-layout">

    <nav class="portfolio-sidebar">
      <p class="portfolio-sidebar-label">What I am...</p>
      <ul class="portfolio-nav-list">
        <li><button
            class="portfolio-nav-item active"
            data-section="spending-my-days-on"
          >Spending my days on</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="spending-my-nights-on"
          >Spending my nights on</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="observing"
          >Observing</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="curating"
          >Curating</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="organizing"
          >Organizing</button></li>
        <li><button class="portfolio-nav-item" data-section="using-ai-for">Using
            AI for</button></li>
        <li><button
            class="portfolio-nav-item"
            data-section="not-using-ai-for"
          >Not using AI for</button></li>
        <li>
          <button
            class="portfolio-nav-item portfolio-see-all"
            data-section="see-everything"
          >See everything</button>
        </li>
      </ul>

    </nav>

    <div class="portfolio-content-area">

      <div id="section-spending-my-days-on" class="portfolio-section visible">
        {{#get
          "posts"
          limit="20"
          filter="tag:spending-my-days-on"
          order="published_at desc"
          as |posts meta|
        }}
          {{#foreach posts}}
            <div class="portfolio-post-item">
              {{#if feature_image}}
                <img
                  srcset="{{> srcset}}"
                  sizes="(min-width: 1200px) 800px, 92vw"
                  src="{{img_url feature_image size="l"}}"
                  alt="{{title}}"
                  class="portfolio-post-feature-image"
                />
              {{/if}}
              <a href="{{url}}" class="portfolio-post-link">
                <h4 class="portfolio-post-title">{{title}}</h4>
              </a>
              <p class="portfolio-post-excerpt">{{excerpt words="30"}}</p>
            </div>
          {{/foreach}}
        {{/get}}
      </div>

